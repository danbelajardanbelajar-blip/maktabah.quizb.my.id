Options -Indexes
RewriteEngine On

# Allow direct access to real files/dirs
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Allow api.php directly
RewriteRule ^api\.php$ - [L]

# Route everything else to index.php (SPA shell)
RewriteRule ^ index.php [L]
